# ROAD Blogger environment example
#
# SQLcl saved connections expected by bin/run-sql.sh:
#   road_blogger_dev
#   app_test
#   app_prod
#
# Hosted ORDS root, without a trailing slash.
# Example:
# ROAD_ORDS_HOST=https://example.adb.region.oraclecloudapps.com
ROAD_ORDS_HOST=

# Optional browser/admin test credentials, once admin auth is implemented.
ROAD_ADMIN_USERNAME=
ROAD_ADMIN_PASSWORD=
